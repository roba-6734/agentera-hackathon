# OPENAI_API_KEY: Required for OpenAI API calls.
# Configure this in your local environment or deployment secret manager.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# Optional OpenAI runtime controls.
# OPENAI_MODEL="gpt-5.5"
# OPENAI_FALLBACK_MODELS="gpt-5.4-mini,gpt-4.1-mini"
# OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
# OPENAI_CACHE_TTL_MS=300000
# OPENAI_RATE_LIMIT_COOLDOWN_MS=60000

# Optional voice transcription controls. If VOICE_TRANSCRIPTION_PROVIDER is
# omitted, the server uses OpenAI when OPENAI_API_KEY is configured; otherwise
# it returns a clearly marked mock transcript for UI development.
# VOICE_TRANSCRIPTION_PROVIDER="openai"
# VOICE_TRANSCRIPTION_MIN_DURATION_MS=700
# VOICE_TRANSCRIPTION_MIN_BYTES=1600
# VOICE_TRANSCRIPTION_MAX_BYTES=10485760

# Optional Neon JSONB context controls.
# The server derives briefing context from country_intelligence_profiles JSONB sections.
# VECTOR_CONTEXT_LIMIT=6

# Optional Neon-backed country intelligence profiles.
# The server prefers this Postgres table for country profiles, then falls back
# to local standby data if Neon is unavailable.
# Expected table: country_intelligence_profiles
# NEON_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"
# NEON_COUNTRY_LIMIT=500

# Optional n8n chat workflow integration.
# When set, chatbot questions are sent server-side to this webhook with
# threadId, recent conversation history, country profile, vector context, and
# meeting memory. If the workflow is unavailable, the app falls back to the
# local grounded advisor response.
# N8N_CHAT_WEBHOOK_URL="MY_N8N_CHAT_WEBHOOK_URL"
# N8N_CHAT_WEBHOOK_SECRET="MY_SHARED_SECRET"
# N8N_CHAT_TIMEOUT_MS=45000
# N8N_CHAT_HISTORY_LIMIT=16

# Optional DeepL translation controls. Free API keys ending in ":fx" use the
# api-free.deepl.com endpoint automatically.
# DEEPL_API_KEY="MY_DEEPL_API_KEY"
# DEEPL_API_URL="https://api-free.deepl.com/v2/translate"
# DEEPL_CACHE_TTL_MS=86400000
# DEEPL_BATCH_SIZE=40

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
