# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional Gemini runtime controls.
# GEMINI_MODEL="gemini-3.5-flash"
# GEMINI_FALLBACK_MODELS="gemini-3.1-flash-lite,gemini-flash-latest"
# GEMINI_CACHE_TTL_MS=300000
# GEMINI_QUOTA_COOLDOWN_MS=60000

# Optional Firestore-backed vector context controls.
# The server reads country profile documents from `countries/{countryId}` and
# vector context chunks from this collection using the existing Firebase config.
# VECTOR_CONTEXT_COLLECTION="countryVectors"
# VECTOR_CONTEXT_LIMIT=6

# Optional DeepL translation controls. Free API keys ending in ":fx" use the
# api-free.deepl.com endpoint automatically.
# DEEPL_API_KEY="MY_DEEPL_API_KEY"
# DEEPL_API_URL="https://api-free.deepl.com/v2/translate"
# DEEPL_CACHE_TTL_MS=86400000
# DEEPL_BATCH_SIZE=40

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
