rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity Test Target
    match /test/connection {
      allow read: if true;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Country Validation Helper
    function isValidCountry(data) {
      return data.id is string && data.id.size() <= 100
        && data.nameEn is string && data.nameEn.size() <= 128
        && data.nameAr is string && data.nameAr.size() <= 128
        && (data.flag == null || (data.flag is string && data.flag.size() <= 16));
    }

    // Meeting Session Validation Helper
    function isValidMeeting(data) {
      return data.id is string && data.id.size() <= 128
        && data.countryName is string && data.countryName.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.date is string && data.date.size() <= 32
        && data.time is string && data.time.size() <= 32;
    }

    // Vector Context Validation Helper
    function isValidVectorContext(data) {
      return data.countryId is string && data.countryId.size() <= 128
        && (data.section == null || (data.section is string && data.section.size() <= 80))
        && (data.titleEn == null || (data.titleEn is string && data.titleEn.size() <= 180))
        && (data.titleAr == null || (data.titleAr is string && data.titleAr.size() <= 180))
        && (data.textEn == null || (data.textEn is string && data.textEn.size() <= 4000))
        && (data.textAr == null || (data.textAr is string && data.textAr.size() <= 4000))
        && (data.sourceUrl == null || (data.sourceUrl is string && data.sourceUrl.size() <= 1000));
    }

    match /countries/{countryId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && isValidId(countryId) 
        && incoming().id == countryId
        && isValidCountry(incoming());
      allow update: if isSignedIn() 
        && isValidId(countryId) 
        && incoming().id == existing().id
        && isValidCountry(incoming());
      allow delete: if isSignedIn() && isValidId(countryId);
    }

    match /meetings/{meetingId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && isValidId(meetingId)
        && incoming().id == meetingId
        && isValidMeeting(incoming());
      allow update: if isSignedIn() 
        && isValidId(meetingId)
        && incoming().id == existing().id
        && isValidMeeting(incoming());
      allow delete: if isSignedIn() && isValidId(meetingId);
    }

    match /countryVectors/{chunkId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidId(chunkId)
        && isValidVectorContext(incoming());
      allow update: if isSignedIn()
        && isValidId(chunkId)
        && isValidVectorContext(incoming());
      allow delete: if isSignedIn() && isValidId(chunkId);
    }
  }
}
